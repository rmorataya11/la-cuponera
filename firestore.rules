rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuario admin de La Cuponera: existe un documento en admins con id = uid.
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Doc de la empresa (solo para no repetir get). Requiere que exista.
    function empresaData(empresaId) {
      return exists(/databases/$(database)/documents/empresas/$(empresaId))
        ? get(/databases/$(database)/documents/empresas/$(empresaId)).data
        : null;
    }
    // True si el usuario autenticado es el admin de la empresa (por UID o por correo del doc = email del token).
    // adminUid: acceso directo y get() por si el doc se editó desde la consola.
    function isAdminOfEmpresa(empresaId) {
      let d = empresaData(empresaId);
      return request.auth != null && empresaId != null
        && d != null
        && (
          d.adminUid == request.auth.uid
          || d.get('adminUid', '') == request.auth.uid
          || (
            request.auth.token.email != null
            && d.get('correo', '') != ''
            && (
              d.get('correo', '') == request.auth.token.email
              || d.correo == request.auth.token.email
            )
          )
        );
    }

    // Panel empresa guarda ofertas con empresa1 cuando el doc de empresa es empresal (typo histórico).
    // Debe coincidir con empleadosEmpresaId / getOfertasPorEmpresa en el cliente.
    function isAdminOfEmpresaParaOferta(empresaIdEnOferta) {
      return request.auth != null && empresaIdEnOferta != null && empresaIdEnOferta != ''
        && (
          isAdminOfEmpresa(empresaIdEnOferta)
          || (empresaIdEnOferta == 'empresa1' && isAdminOfEmpresa('empresal'))
          || (empresaIdEnOferta == 'empresal' && isAdminOfEmpresa('empresa1'))
        );
    }

    // Oferta aprobada (comparación tolerante a mayúsculas).
    function ofertaEstaAprobada() {
      let e = resource.data.get('estado', '');
      return e == 'aprobada' || e == 'Aprobada';
    }

    // Cliente autenticado solo incrementa cuponesVendidos (compra). No sustituye otras ediciones amplias.
    // Nota: no se puede verificar en reglas que exista el batch con cupones; se limita el daño a un solo campo y stock.
    function ofertaUpdateSoloIncrementoVentas() {
      return request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cuponesVendidos'])
        && request.resource.data.cuponesVendidos is number
        && request.resource.data.cuponesVendidos >= resource.data.get('cuponesVendidos', 0)
        && ofertaEstaAprobada()
        && (
          resource.data.get('cantidadLimite') == null
          || request.resource.data.cuponesVendidos <= resource.data.get('cantidadLimite')
        );
    }

    // Admins: solo el propio usuario puede leer. Escritura desde consola/backend.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Rubros: lectura pública. Escritura solo admin.
    match /rubros/{rubroId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Empresas: lectura pública.
    // - Create: admin siempre; o cualquiera puede crear con estado 'pendiente' (registro público de empresa).
    // - Update: admin siempre; o un usuario puede "reclamar" su empresa (poner su uid en adminUid) si el correo coincide y la empresa está aprobada y sin admin aún.
    // - Delete: solo admin.
    match /empresas/{empresaId} {
      allow read: if true;
      allow create: if isAdmin()
        || (request.resource.data.get('estado', '') == 'pendiente'
            && request.resource.data.keys().hasOnly(['nombre', 'codigo', 'direccion', 'nombreContacto', 'telefono', 'correo', 'rubroId', 'porcentajeComision', 'estado']));
      allow update: if isAdmin()
        || (request.auth != null
            && (resource.data.get('estado', '') == 'aprobada' || resource.data.get('estado', '') == '')
            && (resource.data.get('adminUid', null) == null || resource.data.get('adminUid', '') == '')
            && resource.data.get('correo', '') == request.auth.token.email
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['adminUid'])
            && request.resource.data.adminUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Ofertas: lectura pública. Create: admin o admin de la empresa. Update: admin, admin de empresa, o cliente (solo cuponesVendidos +). Delete: solo admin.
    match /ofertas/{ofertaId} {
      allow read: if true;
      allow create: if isAdmin()
        || (request.auth != null
            && request.resource.data.get('empresaId', '') != ''
            && isAdminOfEmpresaParaOferta(request.resource.data.empresaId));
      allow update: if isAdmin()
        || (request.auth != null && resource.data.get('empresaId', '') != '' && isAdminOfEmpresaParaOferta(resource.data.empresaId))
        || ofertaUpdateSoloIncrementoVentas();
      allow delete: if isAdmin();
    }

    // Clientes: cada usuario su documento, o admin lee/escribe todos.
    match /clientes/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // Empleados: acceso amplio (lectura y escritura para cualquiera con la API key del proyecto).
    // La app solo ofrece alta/edición/listado desde el panel empresa; las reglas no restringen quién llama a Firestore.
    match /empleados/{empleadoId} {
      allow read, write: if true;
    }

    // empleadoByUid: el empleado escribe su propio doc { empresaId } para que las reglas de cupones puedan validar.
    match /empleadoByUid/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Cupones: cliente solo los suyos; admin todos; empleado puede leer/actualizar cupones de su empresa (para canje).
    // Tratamos empresal y empresa1 como la misma empresa (typo histórico).
    function empresaIdEmpleado() {
      return exists(/databases/$(database)/documents/empleadoByUid/$(request.auth.uid))
        ? get(/databases/$(database)/documents/empleadoByUid/$(request.auth.uid)).data.get('empresaId', '')
        : '';
    }
    function empleadoPuedeActuarEnCupon(empresaIdCupon) {
      let empId = empresaIdEmpleado();
      return request.auth != null && empresaIdCupon != null && empId != ''
        && (empresaIdCupon == empId
            || (empresaIdCupon == 'empresal' && empId == 'empresa1')
            || (empresaIdCupon == 'empresa1' && empId == 'empresal'));
    }
    match /cupones/{cuponId} {
      allow read: if (request.auth != null && resource.data.clienteId == request.auth.uid) || isAdmin()
        || (resource.data.get('empresaId', null) != null && empleadoPuedeActuarEnCupon(resource.data.empresaId));
      allow create: if request.auth != null && request.resource.data.clienteId == request.auth.uid;
      allow update: if (request.auth != null && resource.data.clienteId == request.auth.uid) || isAdmin()
        || (resource.data.get('empresaId', null) != null && empleadoPuedeActuarEnCupon(resource.data.empresaId)
            && resource.data.estado == 'disponible'
            && request.resource.data.estado == 'canjeado'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'fechaCanje']));
      allow delete: if (request.auth != null && resource.data.clienteId == request.auth.uid) || isAdmin();
    }
  }
}
